{
  "version": 2,
  "buildCommand": "bash vercel_build.sh",
  "outputDirectory": "build/web",
  "functions": {
    "api/ocr.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

